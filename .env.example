# =====================
# DB (local run)
# =====================
DATABASE_URL=sqlite+aiosqlite:///./backend/skin_ai.db

# =====================
# Object Storage (local: MinIO / deploy: Cloudflare R2)
# =====================
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=skin-ai
STORAGE_REGION=us-east-1

# =====================
# AI Model Server
# =====================
AI_MODEL_BASE_URL=http://127.0.0.1:8001

# =====================
# Gemini API
# =====================
GEMINI_API_KEY=

# =====================
# JWT Auth
# =====================
JWT_SECRET=change-this-to-a-random-secret-string
JWT_EXPIRE_MINUTES=60

# =====================
# CORS
# =====================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
