# ── Supabase (PostgreSQL) ─────────────────────────────────────────
# Supabase 대시보드 → Project Settings → Database → Connection string
# "URI" 탭의 값을 복사 후 [YOUR-PASSWORD] 부분을 실제 비밀번호로 교체
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Cloudflare R2 (이미지 저장소) ──────────────────────────────────
# R2 버킷 → Manage R2 API Tokens에서 발급
STORAGE_ENDPOINT=https://[YOUR-ACCOUNT-ID].r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-r2-access-key
STORAGE_SECRET_KEY=your-r2-secret-key
STORAGE_BUCKET=skin-ai

# ── AI Model Server ────────────────────────────────────────────────
AI_MODEL_BASE_URL=http://localhost:8001

# ── Google Gemini API ──────────────────────────────────────────────
# https://aistudio.google.com/app/apikey 에서 발급 (무료)
GEMINI_API_KEY=your-gemini-api-key

# ── JWT ────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=60
